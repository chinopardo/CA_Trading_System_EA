    cfg.scan_lfm_obi_depth_quality_min = 0.20;
    cfg.scan_lfm_dp_flow_quality_min   = 0.15;
    
    // --- Confluence-side LFM gate defaults (read by Confluence when LFM liquidity gates are enabled)
