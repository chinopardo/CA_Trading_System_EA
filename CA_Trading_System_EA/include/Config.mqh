    if(cls == CFG_MS_SYMBOL_XAU)   return cfg.ms_xau_risk_gate_max01;
    if(cls == CFG_MS_SYMBOL_FOREX) return cfg.ms_fx_risk_gate_max01;
    return cfg.ms_other_risk_gate_max01;
