      if(cfg.ms_resil_threshold > 1.0) cfg.ms_resil_threshold = 1.0;

      if(cfg.ms_ofi_weight < 0.0) cfg.ms_ofi_weight = 0.0;
      if(cfg.ms_ofi_weight > 1.0) cfg.ms_ofi_weight = 1.0;

      if(cfg.ms_ofi_abs_min < 0.0) cfg.ms_ofi_abs_min = 0.0;
