    #endif

    #ifdef CFG_HAS_FVG_PARTIAL_FILL_THR
     cfg.fvg_partial_fill_thr = 0.0; // default: legacy "any fill => partial"
     // For spec-default behavior, set to 0.50 instead.
    #endif

